{
  "name": "kanso",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "clean": "rm -rf dist .astro public/pagefind",
    "generate": "astro sync",
    "dev": "astro dev",
    "dev:search": "astro build && pagefind --site dist && cp -r dist/pagefind public/pagefind && astro dev",
    "build": "astro check && astro build && pagefind",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lighthouse": "node scripts/lighthouse.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/ts-plugin": "^1.10.6",
    "@benjc/rehype-enhanced-tables": "^0.1.1",
    "@expressive-code/plugin-line-numbers": "^0.41.6",
    "@pagefind/default-ui": "^1.4.0",
    "astro": "^5.18.0",
    "astro-expressive-code": "^0.41.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,mjs,ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "astro-eslint-parser": "^1.3.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^14.0.0",
    "husky": "^9.1.7",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.2.7",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-css-order": "^2.2.0",
    "typescript-eslint": "^8.55.0"
  }
}
