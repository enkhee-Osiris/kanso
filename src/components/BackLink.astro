---
const arrowLeftIcon = await import("@/assets/icons/arrow-left.svg?raw");

interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a href={href} class="back-link">
  <span class="back-link-icon" set:html={arrowLeftIcon.default} />
  <span class="back-link-text">{label}</span>
</a>

<style>
  /* -------------------------
   * Module — Back Link
   * Icon + label with animated gap on hover
   * ------------------------- */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition:
      color var(--transition),
      gap var(--transition-motion),
      margin var(--transition-motion);
    margin-block-end: 1.5rem;
    padding-block: 0.25rem;
    min-height: 1.5rem;
    color: var(--color-surface-600);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: var(--letter-spacing-caps);
    text-decoration: none;
    text-transform: uppercase;
  }

  /* -------------------------
   * State — Interactive
   * ------------------------- */
  .back-link:hover,
  .back-link:focus-visible {
    gap: 0.75rem;
    margin-inline-start: -0.25rem;
    color: var(--color-accent);
  }

  .back-link:focus-visible {
    outline: var(--focus-outline);
    outline-offset: var(--focus-offset-lg);
    border-radius: var(--focus-radius);
  }

  /* -------------------------
   * Module — Icon
   * ------------------------- */
  .back-link-icon {
    display: flex;
    width: 1rem;
    height: 1rem;
  }

  .back-link-icon :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
